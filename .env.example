# ---------------------------------------------------------------------------
# [COMPANY] website — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# --- Claude API (agent inference) -----------------------------------------
# Default agent model is Claude Haiku 4.5 with prompt caching (see plan Part 4.6).
ANTHROPIC_API_KEY=

# --- Cloudflare data tier (D1 + Vectorize, accessed via REST from Vercel) ---
# Reuses the existing pm-intelligence-agent Cloudflare account + populated
# indexes. Account ID is shared; the token needs D1:Edit + Vectorize:Edit +
# Workers AI:Read (for bge-base-en-v1.5 embeddings). See CLAUDE.md.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# D1 database IDs (from pm-intelligence-agent/Docs/Cloudflare_Resources.md)
D1_PARAMS_DATABASE_ID=18812c7c-0661-4e87-beaa-926b18f13a67
D1_KNOWLEDGE_DATABASE_ID=305c2b6e-3c25-4ac1-b9f6-39ad23422c8d

# --- Cloudflare Turnstile (bot gate on first agent message) ----------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Cost / abuse circuit breaker -----------------------------------------
# Global daily spend ceiling (USD). When exceeded, agents disable and show a
# "contact us" fallback. Enforced in D1 (see /lib/agents/guardrails.ts).
AGENT_DAILY_SPEND_CEILING_USD=25
